# =============================================
# UltimaType Development Environment
# =============================================

# ---- Database ----
DATABASE_URL="postgresql://ultimatype:ultimatype_dev@localhost:5432/ultimatype?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- JWT ----
JWT_SECRET="dev_jwt_secret_change_in_production_32chars"
JWT_REFRESH_SECRET="dev_jwt_refresh_secret_change_in_prod_32"
JWT_EXPIRATION="24h"
JWT_REFRESH_EXPIRATION="7d"

# ---- Google OAuth 2.0 ----
GOOGLE_CLIENT_ID="placeholder"
GOOGLE_CLIENT_SECRET="placeholder"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# ---- GitHub OAuth 2.0 ----
GITHUB_CLIENT_ID="placeholder"
GITHUB_CLIENT_SECRET="placeholder"
GITHUB_CALLBACK_URL="http://localhost:3000/api/auth/github/callback"

# ---- Frontend ----
FRONTEND_URL="http://localhost:4200"
