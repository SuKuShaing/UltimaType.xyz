{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "nodenext",
    "types": ["node"],
    "rootDir": "src",
    "moduleResolution": "nodenext",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@ultimatype-monorepo/shared": ["../../libs/shared/src/index.ts"],
      "@ultimatype-monorepo/prisma-client": ["./generated/prisma/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": []
}
