# =============================================
# UltimaType Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ---- Database ----
DATABASE_URL="postgresql://ultimatype:ultimatype_dev@localhost:5432/ultimatype?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- JWT ----
JWT_SECRET="CHANGE_ME_jwt_secret_min_32_chars_long"
JWT_REFRESH_SECRET="CHANGE_ME_jwt_refresh_secret_min_32_chars"
JWT_EXPIRATION="24h"
JWT_REFRESH_EXPIRATION="7d"

# ---- Google OAuth 2.0 ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# ---- GitHub OAuth 2.0 ----
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:3000/api/auth/github/callback"

# ---- Frontend ----
FRONTEND_URL="http://localhost:4200"
